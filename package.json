    "@types/node": "24.3.0",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7",
    "@types/qrcode": "1.5.5",
    "typescript": "5.9.2"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
